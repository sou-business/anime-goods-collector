{
  "name": "app_batch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "cross-env BATCH_SCHEDULE=development tsx src/index.ts",
    "start": "cross-env BATCH_SCHEDULE=production tsx src/index.ts",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "test:once": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "app_common": "*",
    "cheerio": "^1.1.2",
    "domhandler": "^5.0.3",
    "node-cron": "^4.2.1",
    "redis": "5.11.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "tsc-alias": "^1.8.16"
  }
}