generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  detailUrl String   @unique @map("detail_url") @db.Text
  imageUrl  String  @map("image_url") @db.Text
  title     String
  price     Int

  @@map("products")
}